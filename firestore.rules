rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: caller is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Helper: caller is a player in this room
    function isPlayerInRoom(roomCode) {
      return isAuth()
        && exists(/databases/$(database)/documents/rooms/$(roomCode))
        && request.auth.uid in get(/databases/$(database)/documents/rooms/$(roomCode)).data.players;
    }

    // Helper: the status field has not changed
    function statusUnchanged() {
      return request.resource.data.status == resource.data.status;
    }

    // ─── Rooms ───────────────────────────────────────────────────────
    match /rooms/{roomCode} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isPlayerInRoom(roomCode) && statusUnchanged();
      allow delete: if false; // only Cloud Functions delete rooms

      // ─── Rounds ──────────────────────────────────────────────────
      match /rounds/{roundIndex} {
        allow read: if isPlayerInRoom(roomCode);

        // Players can only update their own playerAnswers entry
        // and cannot change the status field
        allow update: if isPlayerInRoom(roomCode)
          && statusUnchanged()
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['playerAnswers']);

        allow create, delete: if false; // only Cloud Functions

        // ─── Votes ───────────────────────────────────────────────
        match /votes/{voterUid} {
          allow read: if isPlayerInRoom(roomCode);
          allow create, update: if isPlayerInRoom(roomCode)
            && request.auth.uid == voterUid;
          allow delete: if false;
        }
      }
    }
  }
}
